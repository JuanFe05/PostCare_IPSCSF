# ============================================================
#  PostCare IPSCSF — Configuración EJEMPLO
#  Copia este archivo como .env (desarrollo) o .env.production
#  y completa los valores vacíos.
# ============================================================

# --- MySQL ---------------------------------------------------
MYSQL_ROOT_PASSWORD=           # contraseña root de MySQL
MYSQL_DATABASE=postcare_db
MYSQL_USER=postcare_user
MYSQL_PASSWORD=                # contraseña del usuario de la BD

# --- JWT / Security ------------------------------------------
JWT_SECRET=                    # mínimo 32 caracteres aleatorios
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ----------------------------------------------------
# Agrega aquí todas las IPs/equipos desde donde accedan los usuarios
# Ejemplos: http://localhost:41777 o http://192.168.1.100:41777
CORS_ORIGINS=http://localhost:41777

# --- URLs del backend (accesibles desde el navegador) --------
# Cambia localhost por la IP del servidor en producción
FRONTEND_BACKEND_URL=http://localhost:48555
VITE_API_URL=http://localhost:48555
VITE_BACKEND_URL=http://localhost:48555

# --- Versión de la API ---------------------------------------
API_PREFIX=/api/v2

# --- Admin ---------------------------------------------------
# La contraseña se hashea automáticamente con bcrypt durante la migración
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                # contraseña del usuario administrador

# --- Runtime -------------------------------------------------
RUN_STARTUP_TABLES=true
APP_ENV=development            # development | production

# --- Base de datos externa (SQL Server) ----------------------
EXTERNAL_DB_HOST=
EXTERNAL_DB_PORT=1433
EXTERNAL_DB_NAME=
EXTERNAL_DB_USER=
EXTERNAL_DB_PASSWORD=